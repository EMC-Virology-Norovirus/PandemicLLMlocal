fil<-list.files(paste0("C:/Users/ehull/tiktok_pipeline/","/data_covid/"), full.names = F)
cvd<-data.frame(id=NA,like_count=NA, region_code="NL",comment_count=NA,
create_time=NA, hashtag_names='NA', share_count=NA,
video_description='NA', view_count=NA, date=as.Date("2020-01-01"),
count=NA, fil="NA")
for(i in 1:length(fil)){
temp<-read_parquet(paste0("C:/Users/ehull/tiktok_pipeline","/data_covid/",fil[i]))
temp$count<-1
temp$fil<-fil[i]
temp$fil<-temp %>% pull(fil) %>%
str_replace_all(c("covid-19"="",
"covid"="",
"coronavirus"="",
"corona"="",
"SARS"="",
"verkoudheidsklachten"="",
"hoesten"="",
"benauwdheid"="",
"koorts"="",
"neusverkoudheid"="",
"loopneus"="",
"niezen"="",
"keelpijn"=""))
temp$date<-as.Date(substr(temp$fil,2,9), format='%Y%m%d')
temp$fil<-fil[i]
cvd<-rbind(cvd,temp)
}
setDT(cvd)
cvd2<-cvd[!is.na(id)]
cvd2[,week_ct:=sum(count), by=date]
cvd3<-cvd2[,.(week_ct,date)]
cvd3<-cvd3[!duplicated(cvd3)]
cvd3[,norm_ct:=(week_ct-min(week_ct))/(max(week_ct)-min(week_ct))]
cvd3

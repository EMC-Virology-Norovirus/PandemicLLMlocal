mc2[,`:=`(date=NULL, count=NULL, total_count=NULL, ratio=NULL)]
mc2<-mc2[!duplicated(mc2)]
social_weekly <- fb2 %>%
group_by(date = floor_date(date, "week")) %>%
arrange(date) %>%
mutate(social_lag1 = lag(avg_meas, 1))
social_weekly
news_weekly <- mc2 %>%
